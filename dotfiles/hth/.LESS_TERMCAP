export LESS_TERMCAP_mb=$(tput bold; tput setaf 208)   # orange
export LESS_TERMCAP_md=$(tput bold; tput setaf 39)    # bright cyan
export LESS_TERMCAP_me=$(tput sgr0)
export LESS_TERMCAP_so=$(tput bold; tput setaf 226; tput setab 19)  # yellow on dark blue
export LESS_TERMCAP_se=$(tput sgr0)
export LESS_TERMCAP_us=$(tput smul; tput bold; tput setaf 82)  # bright green
export LESS_TERMCAP_ue=$(tput sgr0)
export LESS_TERMCAP_mr=$(tput rev)
export LESS_TERMCAP_mh=$(tput dim)
export GROFF_NO_SGR=1

